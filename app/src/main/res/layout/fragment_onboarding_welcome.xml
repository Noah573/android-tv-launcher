<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wallpaper_1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="64dp">

        <!-- App icon -->
        <ImageView
            android:id="@+id/welcomeIcon"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_launcher_foreground"
            android:layout_marginBottom="32dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/welcomeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_welcome_title"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/welcomeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/onboarding_welcome_desc"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginBottom="48dp" />

        <!-- Start button -->
        <Button
            android:id="@+id/welcomeStartBtn"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:text="@string/onboarding_start"
            android:textSize="18sp"
            android:background="@drawable/bg_button_primary"
            android:textColor="@color/text_primary" />

    </LinearLayout>

</FrameLayout>
