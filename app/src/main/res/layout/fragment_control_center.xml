<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/bg_control_center"
        android:padding="32dp">

        <!-- WiFi toggle -->
        <LinearLayout
            android:id="@+id/wifiToggleRow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:focusable="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/wifiIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_wifi_on" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Wi-Fi"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/wifiSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Bluetooth toggle -->
        <LinearLayout
            android:id="@+id/bluetoothToggleRow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:focusable="true"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/bluetoothIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_bluetooth" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bluetooth"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:layout_marginStart="16dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/bluetoothSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Brightness -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_brightness" />

            <SeekBar
                android:id="@+id/brightnessSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:max="255"
                android:progress="128" />

        </LinearLayout>

        <!-- Volume -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_volume" />

            <SeekBar
                android:id="@+id/volumeSeekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp"
                android:max="100"
                android:progress="50" />

        </LinearLayout>

        <!-- Sleep button -->
        <Button
            android:id="@+id/sleepButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Sleep"
            android:textColor="@color/text_primary"
            android:drawableStart="@drawable/ic_sleep"
            android:drawableTint="@color/text_primary"
            android:background="@android:color/transparent"
            android:focusable="true"
            android:layout_marginTop="16dp" />

        <!-- Settings button -->
        <Button
            android:id="@+id/settingsButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:drawableStart="@drawable/ic_settings"
            android:drawableTint="@color/text_primary"
            android:background="@android:color/transparent"
            android:focusable="true" />

    </LinearLayout>

</FrameLayout>
